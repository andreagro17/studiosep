# ============================================================================
# StudioSeptiembre — Variables de entorno (PLANTILLA)
# ============================================================================
# 1. Copia este archivo como ".env"  →  cp .env.example .env
# 2. Rellena los valores desde: Supabase Dashboard → Project Settings → API
# 3. NUNCA subas el archivo ".env" a git (ya está en .gitignore).
# ============================================================================

# URL del proyecto (Project Settings → API → Project URL)
# Ej.: https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_URL=

# Clave pública "anon" (Project Settings → API → Project API keys → anon public)
# Segura para el navegador; respeta las políticas RLS.
SUPABASE_KEY=

# Clave "service_role" (Project Settings → API → Project API keys → service_role)
# ⚠️ SECRETA. Omite RLS. SOLO se usa en el servidor (server/api), NUNCA en el cliente.
SUPABASE_SERVICE_KEY=
